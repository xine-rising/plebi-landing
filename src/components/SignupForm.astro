---
import { t } from '../i18n/utils';

interface Props {
  audience?: 'general' | 'driver';
}

const { audience = 'general' } = Astro.props;
const formId = `signup-${audience}`;
const msgSuccess = t('signup.success');
const msgErrorInvalid = t('signup.errorInvalid');
const msgErrorGeneric = t('signup.errorGeneric');
const msgErrorRateLimit = t('signup.errorRateLimit');
---

<form id={formId} class="w-full max-w-md mx-auto" novalidate>
  <input type="hidden" name="audience" value={audience} />

  <div class="flex flex-col gap-3">
    <div class="flex flex-col sm:flex-row gap-3">
      <label for={`${formId}-email`} class="sr-only">Email address</label>
      <input
        id={`${formId}-email`}
        type="email"
        name="email"
        inputmode="email"
        autocomplete="email"
        autocapitalize="none"
        spellcheck="false"
        placeholder={t('signup.emailPlaceholder')}
        required
        class="flex-1 px-4 py-3 bg-surface border border-border rounded-lg text-text placeholder:text-text-muted text-base focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent min-h-[44px]"
      />
      <button
        type="submit"
        class="px-6 py-3 bg-primary hover:bg-primary-hover text-white font-semibold rounded-lg transition-colors duration-150 min-h-[44px] w-full sm:w-auto cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary-light focus:ring-offset-2 focus:ring-offset-bg"
      >
        {t('signup.submit')}
      </button>
    </div>

    <label class="flex items-start gap-3 cursor-pointer">
      <input
        type="checkbox"
        name="newsletter_opt_in"
        class="mt-0.5 w-5 h-5 min-w-[20px] min-h-[20px] rounded border-border bg-surface accent-primary cursor-pointer"
      />
      <span class="text-sm text-text-secondary leading-snug">
        {t('signup.newsletterLabel')}
        <span class="block text-text-muted text-xs mt-1">{t('signup.newsletterNote')}</span>
      </span>
    </label>
  </div>

  <div id={`${formId}-status`} class="mt-3 text-sm hidden" role="alert" aria-live="polite"></div>
</form>

<script define:vars={{ formId, msgSuccess, msgErrorInvalid, msgErrorGeneric, msgErrorRateLimit }}>
  const form = document.getElementById(formId);
  const status = document.getElementById(`${formId}-status`);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const btn = form.querySelector('button[type="submit"]');
    const email = fd.get('email')?.toString().trim();

    status.classList.remove('hidden');

    if (!email || !email.includes('@') || !email.includes('.')) {
      status.textContent = msgErrorInvalid;
      status.className = 'mt-3 text-sm text-error';
      return;
    }

    btn.disabled = true;
    btn.classList.add('opacity-50');

    try {
      const res = await fetch('/api/signup.php', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          audience: fd.get('audience'),
          newsletter_opt_in: fd.has('newsletter_opt_in'),
        }),
      });

      const data = await res.json();

      if (res.ok && data.success) {
        status.textContent = msgSuccess;
        status.className = 'mt-3 text-sm text-success';
        form.querySelector('input[type="email"]').disabled = true;
        btn.disabled = true;
      } else if (res.status === 429) {
        status.textContent = msgErrorRateLimit;
        status.className = 'mt-3 text-sm text-error';
        btn.disabled = false;
        btn.classList.remove('opacity-50');
      } else {
        status.textContent = data.error || msgErrorGeneric;
        status.className = 'mt-3 text-sm text-error';
        btn.disabled = false;
        btn.classList.remove('opacity-50');
      }
    } catch {
      status.textContent = msgErrorGeneric;
      status.className = 'mt-3 text-sm text-error';
      btn.disabled = false;
      btn.classList.remove('opacity-50');
    }
  });
</script>
