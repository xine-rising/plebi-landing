---
import { t } from '../i18n/utils';
import { Users } from '@lucide/astro';
---

<section class="px-6 py-16 sm:py-24 bg-surface">
  <div class="max-w-[70ch] mx-auto">
    <div class="flex justify-center mb-6">
      <div class="w-14 h-14 rounded-full bg-bg border border-border flex items-center justify-center">
        <Users class="w-7 h-7 text-gold" aria-hidden="true" />
      </div>
    </div>

    <h2 class="text-text text-2xl sm:text-3xl lg:text-4xl font-bold text-center">
      {t('ownership.heading')}
    </h2>

    <div class="mt-8 space-y-5 text-text-body text-lg leading-[1.7]">
      <p>{t('ownership.p1')}</p>
      <p>{t('ownership.p2')}</p>
      <p class="text-gold font-medium text-xl leading-snug">
        {t('ownership.pullQuote')}
      </p>
      <p>{t('ownership.p3')}</p>
    </div>

    <!-- Check the math accordion -->
    <details class="mt-10 group">
      <summary class="flex items-center justify-center gap-2 cursor-pointer text-primary font-semibold text-base hover:text-primary-light transition-colors duration-150 list-none [&::-webkit-details-marker]:hidden select-none">
        <span>{t('ownership.checkMath.toggle')}</span>
        <svg class="w-4 h-4 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </summary>

      <div class="mt-6 p-6 bg-bg border border-border rounded-2xl space-y-6">
        <p class="text-text-body text-base leading-relaxed">
          {t('ownership.checkMath.intro')}
        </p>

        <!-- Numbers table -->
        <div class="space-y-3">
          <div class="flex justify-between items-baseline py-2 border-b border-border">
            <span class="text-text-secondary text-sm">{t('ownership.checkMath.subscription')}</span>
            <span class="text-text font-semibold">$19.99/mo</span>
          </div>
          <div class="flex justify-between items-baseline py-2 border-b border-border">
            <span class="text-text-secondary text-sm">{t('ownership.checkMath.netAfterApple')}</span>
            <span class="text-text font-semibold">~$17/mo</span>
          </div>
          <div class="flex justify-between items-baseline py-2 border-b border-border">
            <span class="text-text-secondary text-sm">{t('ownership.checkMath.fixedCosts')}</span>
            <span class="text-text font-semibold">~$8K/mo</span>
          </div>
          <div class="flex justify-between items-baseline py-2 border-b border-border">
            <span class="text-text-secondary text-sm">{t('ownership.checkMath.breakeven')}</span>
            <span class="text-gold font-bold">~470 drivers</span>
          </div>
        </div>

        <!-- Scale projection -->
        <div class="space-y-3">
          <p class="text-text text-sm font-semibold uppercase tracking-wide">{t('ownership.checkMath.pastBreakeven')}</p>
          <div class="grid grid-cols-2 gap-4">
            <div class="p-4 bg-surface rounded-xl text-center">
              <p class="text-text-secondary text-sm">1,000 drivers</p>
              <p class="text-gold text-xl font-bold mt-1">~$9K/mo</p>
              <p class="text-text-muted text-xs mt-1">{t('ownership.checkMath.distributable')}</p>
            </div>
            <div class="p-4 bg-surface rounded-xl text-center">
              <p class="text-text-secondary text-sm">2,000 drivers</p>
              <p class="text-gold text-xl font-bold mt-1">~$26K/mo</p>
              <p class="text-text-muted text-xs mt-1">{t('ownership.checkMath.distributable')}</p>
            </div>
          </div>
        </div>

        <p class="text-text-body text-base leading-relaxed">
          {t('ownership.checkMath.commitment')}
        </p>

        <p class="text-text-muted text-xs leading-relaxed italic">
          {t('ownership.checkMath.footnote')}
        </p>
      </div>
    </details>

    <!-- Membership framing + interest form -->
    <div class="mt-12 text-center">
      <p class="text-text-body text-base leading-relaxed max-w-prose mx-auto mb-6">
        {t('ownership.membership.framing')}
      </p>

      <div class="founding-interest-flow max-w-md mx-auto" data-state="form">
        <!-- Form -->
        <div class="interest-form">
          <button
            type="button"
            class="interest-toggle-btn w-full px-6 py-3 bg-primary hover:bg-primary-hover text-white font-semibold rounded-lg transition-colors duration-150 min-h-[44px] cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary-light focus:ring-offset-2 focus:ring-offset-bg"
          >
            {t('ownership.membership.cta')}
          </button>

          <form class="interest-fields hidden mt-6 space-y-4 text-left" novalidate>
            <!-- Honeypot -->
            <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />

            <div>
              <label for="fi-name" class="text-text text-sm font-medium block mb-1">{t('ownership.membership.nameLabel')}</label>
              <input id="fi-name" type="text" name="name" required autocomplete="name"
                class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text placeholder:text-text-muted text-base focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent min-h-[44px]" />
            </div>

            <div>
              <label for="fi-email" class="text-text text-sm font-medium block mb-1">{t('ownership.membership.emailLabel')}</label>
              <input id="fi-email" type="email" name="email" required autocomplete="email" autocapitalize="none"
                class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text placeholder:text-text-muted text-base focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent min-h-[44px]" />
            </div>

            <div>
              <label for="fi-city" class="text-text text-sm font-medium block mb-1">{t('ownership.membership.cityLabel')}</label>
              <input id="fi-city" type="text" name="city_state" autocomplete="address-level2"
                class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text placeholder:text-text-muted text-base focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent min-h-[44px]"
                placeholder="e.g. Portland, OR" />
            </div>

            <label class="flex items-start gap-3 cursor-pointer py-1">
              <input type="checkbox" name="is_driver"
                class="mt-0.5 w-5 h-5 min-w-[20px] min-h-[20px] rounded border-border bg-bg accent-primary cursor-pointer" />
              <span class="text-text text-sm leading-snug">{t('ownership.membership.driverCheckbox')}</span>
            </label>

            <div>
              <label for="fi-note" class="text-text text-sm font-medium block mb-1">{t('ownership.membership.noteLabel')}</label>
              <textarea id="fi-note" name="note" rows="3" maxlength="2000"
                class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text placeholder:text-text-muted text-base focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-y"
                placeholder={t('ownership.membership.notePlaceholder')}></textarea>
            </div>

            <button type="submit"
              class="w-full px-6 py-3 bg-primary hover:bg-primary-hover text-white font-semibold rounded-lg transition-colors duration-150 min-h-[44px] cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary-light focus:ring-offset-2 focus:ring-offset-bg">
              {t('ownership.membership.submit')}
            </button>

            <div class="interest-status text-sm hidden" role="alert" aria-live="polite"></div>
          </form>
        </div>

        <!-- Success -->
        <div class="interest-success hidden text-center py-4">
          <p class="text-success text-lg font-semibold">{t('ownership.membership.successHeadline')}</p>
          <p class="mt-2 text-text-body text-base">{t('ownership.membership.successDetail')}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.founding-interest-flow').forEach((flow) => {
    const toggleBtn = flow.querySelector('.interest-toggle-btn');
    const fields = flow.querySelector('.interest-fields');
    const form = flow.querySelector('.interest-fields');
    const statusEl = flow.querySelector('.interest-status');
    const successEl = flow.querySelector('.interest-success');
    const formContainer = flow.querySelector('.interest-form');

    toggleBtn?.addEventListener('click', () => {
      toggleBtn.classList.add('hidden');
      fields?.classList.remove('hidden');
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      const fd = new FormData(form);

      const name = fd.get('name')?.toString().trim();
      const email = fd.get('email')?.toString().trim();

      if (!name) { showError('Please enter your name.'); return; }
      if (!email || !email.includes('@')) { showError('Please enter a valid email.'); return; }

      btn.disabled = true;
      btn.classList.add('opacity-50');

      try {
        const res = await fetch('https://api.plebi.app/api/v1/founding-interest', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name,
            email,
            city_state: fd.get('city_state')?.toString().trim() || null,
            is_driver: form.querySelector('input[name="is_driver"]').checked,
            note: fd.get('note')?.toString().trim() || null,
            website: fd.get('website')?.toString() || '',
          }),
        });

        if (res.ok || res.status === 201) {
          formContainer?.classList.add('hidden');
          successEl?.classList.remove('hidden');
        } else if (res.status === 429) {
          showError('Too many attempts. Please try again later.');
        } else {
          const data = await res.json().catch(() => ({}));
          showError(data.message || 'Something went wrong. Please try again.');
        }
      } catch {
        showError('Something went wrong. Please try again.');
      } finally {
        btn.disabled = false;
        btn.classList.remove('opacity-50');
      }
    });

    function showError(msg) {
      statusEl.textContent = msg;
      statusEl.className = 'interest-status text-sm text-error mt-2';
    }
  });
</script>
