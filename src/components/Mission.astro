---
import { t } from '../i18n/utils';
---

<section class="px-6 py-16 sm:py-24">
  <div class="max-w-[70ch] mx-auto">
    <h2 class="text-text text-2xl sm:text-3xl lg:text-4xl font-bold text-center">
      {t('mission.heading')}
    </h2>

    <div class="mt-10 space-y-6 text-text-body text-lg leading-[1.7]">
      <p>{t('mission.p1')}</p>
      <p>{t('mission.p2')}</p>
      <p class="text-text font-medium">{t('mission.p3')}</p>
    </div>
  </div>
</section>
