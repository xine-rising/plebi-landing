---
import { t } from '../i18n/utils';
import { TESTFLIGHT_URL } from '../config';
import { FlaskConical } from '@lucide/astro';
---

<section class="px-6 py-10 sm:py-14">
  <div class="max-w-2xl mx-auto p-6 bg-surface border border-border rounded-2xl flex flex-col sm:flex-row items-center gap-6 text-center sm:text-left">
    <FlaskConical class="w-10 h-10 text-gold flex-shrink-0" aria-hidden="true" />
    <div class="flex-1">
      <p class="text-text text-lg font-semibold">{t('beta.heading')}</p>
      <p class="mt-1 text-text-body text-base leading-relaxed">{t('beta.body')}</p>
    </div>
    <a
      href={TESTFLIGHT_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="px-6 py-3 bg-primary hover:bg-primary-hover text-white font-semibold rounded-lg transition-colors duration-150 min-h-[44px] whitespace-nowrap"
    >
      {t('beta.cta')}
    </a>
  </div>
</section>
