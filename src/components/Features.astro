---
import { t } from '../i18n/utils';
import AppStoreBadge from './AppStoreBadge.astro';
import { DollarSign, Shield, Calendar, Wrench } from '@lucide/astro';
---

<section class="px-6 py-16 sm:py-24">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-text text-2xl sm:text-3xl lg:text-4xl font-bold text-center">
      {t('features.heading')}
    </h2>
    <p class="mt-4 text-text-body text-lg sm:text-xl text-center max-w-2xl mx-auto leading-relaxed">
      {t('features.intro')}
    </p>

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-6 sm:gap-8">
      <div class="p-6 bg-surface border border-border rounded-2xl">
        <DollarSign class="w-8 h-8 text-gold mb-4" aria-hidden="true" />
        <h3 class="text-text text-lg font-semibold">
          {t('features.props.listing.title')}
        </h3>
        <p class="mt-2 text-text-body text-base leading-relaxed">
          {t('features.props.listing.description')}
        </p>
      </div>

      <div class="p-6 bg-surface border border-border rounded-2xl">
        <Shield class="w-8 h-8 text-gold mb-4" aria-hidden="true" />
        <h3 class="text-text text-lg font-semibold">
          {t('features.props.freedom.title')}
        </h3>
        <p class="mt-2 text-text-body text-base leading-relaxed">
          {t('features.props.freedom.description')}
        </p>
      </div>

      <div class="p-6 bg-surface border border-border rounded-2xl">
        <Calendar class="w-8 h-8 text-gold mb-4" aria-hidden="true" />
        <h3 class="text-text text-lg font-semibold">
          {t('features.props.schedule.title')}
        </h3>
        <p class="mt-2 text-text-body text-base leading-relaxed">
          {t('features.props.schedule.description')}
        </p>
      </div>

      <div class="p-6 bg-surface border border-border rounded-2xl">
        <Wrench class="w-8 h-8 text-gold mb-4" aria-hidden="true" />
        <h3 class="text-text text-lg font-semibold">
          {t('features.props.experience.title')}
        </h3>
        <p class="mt-2 text-text-body text-base leading-relaxed">
          {t('features.props.experience.description')}
        </p>
      </div>
    </div>

    <div class="mt-12 flex justify-center">
      <AppStoreBadge />
    </div>
  </div>
</section>
