---
import { t } from '../i18n/utils';
---

<section class="px-6 py-16 sm:py-24 bg-surface">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-text text-2xl sm:text-3xl lg:text-4xl font-bold text-center">
      {t('howItWorks.heading')}
    </h2>

    <ol class="mt-12 space-y-10 sm:space-y-12">
      {[
        { step: t('howItWorks.step1'), desc: t('howItWorks.step1Desc') },
        { step: t('howItWorks.step2'), desc: t('howItWorks.step2Desc') },
        { step: t('howItWorks.step3'), desc: t('howItWorks.step3Desc') },
        { step: t('howItWorks.step4'), desc: t('howItWorks.step4Desc') },
      ].map((item, i) => (
        <li class="flex gap-5 sm:gap-6">
          <span class="flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-bg border border-border flex items-center justify-center text-gold font-bold text-lg sm:text-xl" aria-hidden="true">
            {i + 1}
          </span>
          <div>
            <h3 class="text-text text-lg sm:text-xl font-semibold">{item.step}</h3>
            <p class="mt-1 text-text-body text-base sm:text-lg leading-relaxed max-w-prose">{item.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
